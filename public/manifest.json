{
  "manifest_version": 3,
  "name": "ChaoJia",
  "version": "0.1.0",
  "description": "同时和 ChatGPT、Gemini 对话的聊天聚合器",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://openai.com/*",
    "https://*.openai.com/*",
    "https://images.openai.com/*",
    "https://gemini.google.com/*",
    "https://*.gemini.google.com/*",
    "https://accounts.google.com/*",
    "https://apis.google.com/*",
    "https://ogs.google.com/*",
    "https://www.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://*.gstatic.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://chatgpt.com https://*.chatgpt.com https://chat.openai.com https://gemini.google.com https://*.gemini.google.com https://accounts.google.com https://apis.google.com https://ogs.google.com https://www.google.com https://*.googleusercontent.com https://*.gstatic.com;"
  },
  "action": {
    "default_title": "ChaoJia",
    "default_icon": {
      "16": "icons/chaojia-16.png",
      "32": "icons/chaojia-32.png",
      "48": "icons/chaojia-48.png",
      "128": "icons/chaojia-128.png"
    }
  },
  "icons": {
    "16": "icons/chaojia-16.png",
    "32": "icons/chaojia-32.png",
    "48": "icons/chaojia-48.png",
    "128": "icons/chaojia-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://gemini.google.com/*",
        "*://*.gemini.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "chaojia_frame_rules",
        "enabled": true,
        "path": "frame-rules.json"
      }
    ]
  }
}
